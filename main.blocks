rue"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="text"><shadow type="text" id="1yvQljlOi6VA4f@Xb?6c"><field name="TEXT">You aren't even human. You are the fidget spinner.</field></shadow></value><value name="x"><shadow type="math_number" id="zH3*ZzM;iM3[C=XNd7zO"><field name="NUM">80</field></shadow></value><value name="y"><shadow type="math_number" id="*`FRpY5$T!i31lLk)wU5"><field name="NUM">90</field></shadow></value><value name="width"><shadow type="math_number" id="7q4.tnR)QsT{=BmjDy`*"><field name="NUM">150</field></shadow></value><value name="height"><shadow type="math_number" id="Dj_5PJg;!.o*E{5=VnO3"><field name="NUM">50</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id="W|yDtIb[n0S~vQ(C_Bmd"><field name="index">15</field></shadow></value><value name="background"><shadow type="colorindexpicker" id="U:B}aOrs3?6PX2OJYuJ6"><field name="index">1</field></shadow></value><next><block type="device_pause" id="Syxa6heoT+R$o7o8hcWz"><value name="pause"><shadow type="timePicker" id="bO+-`fKEh_(C6qPCQB#!"><field name="ms">500</field></shadow></value><next><block type="story_print_dialog" id="5RhKf9%uRX^2QJeirg,G"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="speed">story.TextSpeed.VerySlow</field><value name="text"><shadow type="text" id="*@hx)N}5x;)X1E==_F`_"><field name="TEXT">This game is about society.</field></shadow></value><value name="x"><shadow type="math_number" id=",lDqn2W*,^SxkJtl36yK"><field name="NUM">80</field></shadow></value><value name="y"><shadow type="math_number" id="+y7XV.QS`HN8BqL-%z7Y"><field name="NUM">90</field></shadow></value><value name="width"><shadow type="math_number" id="XRUY2Z6Xk5WI=P%bM|4f"><field name="NUM">150</field></shadow></value><value name="height"><shadow type="math_number" id="kJ!ARw?_PP^axFlmeyuw"><field name="NUM">50</field></shadow></value><value name="foreground"><shadow type="colorindexpicker" id=",